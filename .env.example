# Required — Devin API credentials
DEVIN_API_TOKEN=your_devin_api_token_here
DEVIN_ORG_ID=your_devin_org_id_here

# Optional — GitHub webhook signature verification
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# Optional — fallback repo URL if not present in the webhook payload
TARGET_REPO_URL=https://github.com/torrancefredell/superset

# Optional — override for local development / testing
# DATABASE_URL=sqlite:///./devin_sessions.db
# DEVIN_API_BASE_URL=https://api.devin.ai/v3
